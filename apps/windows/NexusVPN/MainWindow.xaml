<Window
    x:Class="NexusVPN.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NexusVPN">

    <!-- Deep Dark Theme Native Background -->
    <Grid Background="#0F0F12">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="40">
            
            <!-- Glassmorphism Glowing Indicator around Button -->
            <Border x:Name="GlowBorder" Width="220" Height="220" CornerRadius="110" 
                    Background="#33444444" 
                    BorderBrush="#33FFFFFF" BorderThickness="1">
                
                <Button x:Name="ConnectBtn" Width="180" Height="180" CornerRadius="90"
                        Background="#000000" Foreground="White"
                        FontSize="24" FontWeight="Bold"
                        Click="ConnectBtn_Click">
                    <TextBlock x:Name="BtnText" Text="CONNECT" />
                </Button>
            </Border>
            
            <!-- Minimalist Status Text -->
            <TextBlock x:Name="StatusText" Text="STATUS: DISCONNECTED" 
                       Foreground="DarkGray" FontSize="18" 
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
