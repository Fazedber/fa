<Window
    x:Class="NexusVPN.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nebula VPN"
    Width="460"
    Height="620"
    WindowStartupLocation="CenterScreen"
    Background="#0D1017">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock
                x:Name="BrandTitle"
                Text="Nebula VPN"
                FontSize="30"
                FontWeight="SemiBold"
                Foreground="White" />
            <TextBlock
                Margin="0,8,0,0"
                Text="Desktop tunnel controller"
                FontSize="14"
                Foreground="#99A7BF" />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border
                x:Name="GlowBorder"
                Width="220"
                Height="220"
                CornerRadius="110"
                Background="#20354466"
                BorderBrush="#40A7E5FF"
                BorderThickness="1"
                Padding="18">
                <Button
                    x:Name="ConnectBtn"
                    Click="ConnectBtn_Click"
                    Cursor="Hand"
                    Background="#0B1623"
                    Foreground="White"
                    BorderBrush="#55A7E5FF"
                    BorderThickness="1"
                    FontSize="24"
                    FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="92">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="BtnText" Text="CONNECT" />
                </Button>
            </Border>

            <TextBlock
                x:Name="StatusText"
                Margin="0,28,0,0"
                Text="STATUS: DISCONNECTED"
                FontSize="16"
                Foreground="#A0ABB9"
                HorizontalAlignment="Center" />
        </StackPanel>

        <Border
            Grid.Row="2"
            CornerRadius="16"
            Padding="14"
            Background="#151C28"
            BorderBrush="#223044"
            BorderThickness="1">
            <TextBlock
                Text="If the daemon is not running, the UI will stay disconnected until the service starts."
                TextWrapping="Wrap"
                Foreground="#8D9AAF"
                FontSize="13" />
        </Border>
    </Grid>
</Window>
